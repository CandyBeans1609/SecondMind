# ─────────────────────────────────────────────────────────────────────────────
# SecondMind — environment configuration
# Copy this file to .env and fill in / adjust values as needed.
# All variables are optional; the defaults in config.py are used if omitted.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Ollama ────────────────────────────────────────────────────────────────────

# URL of your running Ollama instance.
# Default: http://localhost:11434  (Ollama's standard port)
# Change this if Ollama is running on a different host or port (e.g. Docker).
OLLAMA_BASE_URL=http://localhost:11434

# LLM used for answer generation.
# Must be a valid Ollama model tag — will be pulled automatically on startup.
# Swap for a smaller model (e.g. phi3:mini, mistral:7b) on low-VRAM machines.
LLM_MODEL=llama3.2:latest

# Model used to create document and query embeddings.
# nomic-embed-text is fast, accurate, and only ~274 MB.
# Alternatives: mxbai-embed-large (higher quality), all-minilm (fastest)
EMBED_MODEL=nomic-embed-text


# ── Embedding strategy ────────────────────────────────────────────────────────

# true  → use /api/embed (one round-trip, requires Ollama ≥ 0.1.34)
# false → fall back to parallel /api/embeddings calls (one request per chunk)
EMBED_USE_BATCH=true

# Maximum number of text chunks sent per /api/embed request.
# Reduce if you hit Ollama memory limits on large documents.
EMBED_BATCH_SIZE=32

# Number of parallel workers used when EMBED_USE_BATCH=false.
EMBED_CONCURRENCY=8


# ── Chunking ──────────────────────────────────────────────────────────────────

# Characters per chunk. Increase for longer-context models (e.g. 2000).
# Decrease for faster embedding and more precise retrieval (e.g. 512).
CHUNK_SIZE=1000

# Overlap between consecutive chunks (characters).
# Helps preserve context at chunk boundaries. Typically 10–20% of CHUNK_SIZE.
CHUNK_OVERLAP=150


# ── Retrieval ─────────────────────────────────────────────────────────────────

# Number of chunks returned per query.
# Higher values give the LLM more context but increase prompt size and latency.
TOP_K=4

# Minimum cosine-similarity score (0.0–1.0) required to include a chunk.
# 0.0 = disabled (return all top-k regardless of score).
# Try 0.3–0.5 to filter out loosely related chunks.
SIMILARITY_THRESHOLD=0.0


# ── Generation ────────────────────────────────────────────────────────────────

# Maximum tokens the LLM may generate per response.
MAX_TOKENS=1024

# Sampling temperature.
# 0.0 = deterministic / factual answers (recommended for RAG)
# 1.0 = creative / varied answers
TEMPERATURE=0.2

# System prompt injected at the start of every conversation.
# Keep it concise. The RAG context and question are appended automatically.
SYSTEM_PROMPT=You are a helpful assistant that answers questions strictly based on the provided context. If the context does not contain enough information to answer the question, say so clearly. Do not make up information.


# ── ChromaDB ──────────────────────────────────────────────────────────────────

# Name of the ChromaDB collection that stores document embeddings.
# Change this if you want to maintain multiple independent knowledge bases.
CHROMA_COLLECTION=documents
